# Web UI Environment Variables
# =============================
# Copy this file to .env and adjust as needed.
# All variables are optional — defaults use localhost.

# Exchange Simulator WebSocket URL (market data, order execution)
VITE_WS_EXCHANGE=ws://localhost:8765

# AI Signal Bot WebSocket URL (signals, market regime, backtest)
VITE_WS_SIGNALS=ws://localhost:8766

# Notes:
# - For Docker, use ws://localhost:8765 / ws://localhost:8766 (ports are mapped to host)
# - For remote deployment, replace localhost with your server address
# - .env is gitignored — never commit real connection strings
