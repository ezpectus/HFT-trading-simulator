{
  "name": "trading-sim-web-ui",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "HFT Trading System Dashboard — 191+ panels, 75+ math models, React 18 + Vite 5",
  "keywords": ["trading", "hft", "react", "dashboard", "crypto", "fintech", "visualization"],
  "author": "Trading System",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "build:mock": "VITE_MOCK_MODE=true vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "analyze": "vite-bundle-visualizer"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lightweight-charts": "^4.2.0",
    "lucide-react": "^0.400.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.3",
    "vite-bundle-visualizer": "^1.2.0",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^1.6.0"
  }
}
