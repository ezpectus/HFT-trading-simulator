{
  "name": "trading-sim-web-ui",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "HFT Trading System Dashboard — 191+ panels, 75+ math models, React 18 + Vite 5",
  "keywords": [
    "trading",
    "hft",
    "react",
    "dashboard",
    "crypto",
    "fintech",
    "visualization"
  ],
  "author": "Trading System",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "build:mock": "VITE_MOCK_MODE=true vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src/",
    "analyze": "vite-bundle-visualizer"
  },
  "dependencies": {
    "lightweight-charts": "^4.2.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.6.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.25.0",
    "eslint": "^9.6.0",
    "eslint-plugin-react": "^7.35.0",
    "globals": "^15.0.0",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "vite": "^8.1.4",
    "vite-bundle-visualizer": "^1.2.0",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
